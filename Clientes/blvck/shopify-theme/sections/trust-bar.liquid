{%- style -%}
  #shopify-section-{{ section.id }} .trust-bar {
    background-color: {{ section.settings.bg_color }};
    border-top: 1px solid {{ section.settings.border_color }};
    border-bottom: 1px solid {{ section.settings.border_color }};
    padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;
    overflow: hidden;
    position: relative;
    display: flex;
    align-items: center;
  }

  .trust-bar__marquee {
    display: flex;
    align-items: center;
    width: max-content;
    animation: marquee {{ section.settings.speed }}s linear infinite;
    will-change: transform;
  }

  /* Pausa ao passar o mouse para melhor UX */
  {%- if section.settings.pause_on_hover -%}
    #shopify-section-{{ section.id }} .trust-bar:hover .trust-bar__marquee {
      animation-play-state: paused;
    }
  {%- endif -%}

  .trust-bar__item {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 0 50px; /* Espaçamento entre os benefícios */
    white-space: nowrap;
    flex-shrink: 0;
  }

  .trust-bar__icon svg {
    width: 20px;
    height: 20px;
    color: {{ section.settings.icon_color }};
  }

  .trust-bar__text {
    display: flex;
    flex-direction: column;
  }

  .trust-bar__title {
    margin: 0;
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: {{ section.settings.text_color }};
    line-height: 1;
  }

  .trust-bar__subtitle {
    margin: 4px 0 0;
    font-size: 10px;
    color: {{ section.settings.text_color }};
    opacity: 0.5;
    line-height: 1;
    text-transform: lowercase;
  }

  @keyframes marquee {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); } /* Loop perfeito na metade */
  }

  /* Responsivo */
  @media screen and (max-width: 767px) {
    .trust-bar__item {
      padding: 0 30px;
    }
    #shopify-section-{{ section.id }} .trust-bar {
      padding: 12px 0;
    }
  }
{%- endstyle -%}

<div class="trust-bar" aria-label="Benefícios da Loja">
  <div class="trust-bar__marquee">
    {%- comment -%} Renderizamos os blocos duas vezes para o efeito de loop infinito suave {%- endcomment -%}
    {%- for i in (1..2) -%}
      {%- for block in section.blocks -%}
        <div class="trust-bar__item" {{ block.shopify_attributes }}>
          {% if block.settings.icon_svg != blank %}
            <div class="trust-bar__icon">
              {{ block.settings.icon_svg }}
            </div>
          {% endif %}
          <div class="trust-bar__text">
            <p class="trust-bar__title">{{ block.settings.title }}</p>
            <p class="trust-bar__subtitle">{{ block.settings.subtitle }}</p>
          </div>
        </div>
      {%- endfor -%}
    {%- endfor -%}
  </div>
</div>

{% schema %}
{
  "name": "Barra de Confiança Noir",
  "settings": [
    {
      "type": "header",
      "content": "Estilo Noir"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Cor de Fundo",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Cor do Texto",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "icon_color",
      "label": "Cor do Ícone",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Cor da Borda",
      "default": "#f0f0f0"
    },
    {
      "type": "range",
      "id": "speed",
      "min": 10,
      "max": 80,
      "step": 2,
      "unit": "s",
      "label": "Velocidade do Movimento",
      "default": 35
    },
    {
      "type": "checkbox",
      "id": "pause_on_hover",
      "label": "Pausar ao passar o mouse",
      "default": true
    },
    {
      "type": "header",
      "content": "Espaçamento"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Espaço Superior",
      "default": 18
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Espaço Inferior",
      "default": 18
    }
  ],
  "blocks": [
    {
      "type": "benefit",
      "name": "Benefício Noir",
      "settings": [
        {
          "type": "html",
          "id": "icon_svg",
          "label": "Ícone SVG"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Título",
          "default": "Frete Grátis"
        },
        {
          "type": "text",
          "id": "subtitle",
          "label": "Subtítulo",
          "default": "em todas as compras"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Barra de Confiança Noir",
      "blocks": [
        { "type": "benefit", "settings": { "title": "Envio Premium", "subtitle": "Curadoria exclusiva" } },
        { "type": "benefit", "settings": { "title": "Troca Noir", "subtitle": "Simples e ágil" } },
        { "type": "benefit", "settings": { "title": "Pagamento Seguro", "subtitle": "Até 12x sem juros" } },
        { "type": "benefit", "settings": { "title": "Atendimento VIP", "subtitle": "Suporte especializado" } }
      ]
    }
  ]
}
{% endschema %}