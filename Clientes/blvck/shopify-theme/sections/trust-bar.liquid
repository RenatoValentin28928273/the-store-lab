{%- style -%}
  #shopify-section-{{ section.id }} .trust-bar {
    background-color: {{ section.settings.bg_color }};
    border-top: 1px solid {{ section.settings.border_color }};
    border-bottom: 1px solid {{ section.settings.border_color }};
    padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;
  }

  .trust-bar__container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 15px;
  }

  .trust-bar__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 15px;
    align-items: center;
  }

  .trust-bar__item {
    display: flex;
    align-items: center;
    justify-content: flex-start;
    gap: 12px;
  }

  .trust-bar__icon svg {
    width: 24px;
    height: 24px;
    color: {{ section.settings.icon_color }};
  }

  .trust-bar__text {
    display: flex;
    flex-direction: column;
  }

  .trust-bar__title {
    margin: 0;
    font-size: 13px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    color: {{ section.settings.text_color }};
    line-height: 1.2;
  }

  .trust-bar__subtitle {
    margin: 3px 0 0;
    font-size: 11px;
    color: {{ section.settings.text_color }};
    opacity: 0.7;
    line-height: 1.2;
  }

  /* Ajustes para Desktop */
  @media screen and (min-width: 768px) {
    .trust-bar__grid {
      grid-template-columns: repeat({{ section.blocks.size | at_most: 4 }}, 1fr);
      gap: 20px;
    }
    
    .trust-bar__item {
      justify-content: center;
    }
    
    .trust-bar__title {
      font-size: 12px;
    }
  }
{%- endstyle -%}

<div class="trust-bar">
  <div class="trust-bar__container">
    <div class="trust-bar__grid">
      {%- for block in section.blocks -%}
        <div class="trust-bar__item" {{ block.shopify_attributes }}>
          <div class="trust-bar__icon">
            {{ block.settings.icon_svg }}
          </div>
          <div class="trust-bar__text">
            <p class="trust-bar__title">{{ block.settings.title }}</p>
            <p class="trust-bar__subtitle">{{ block.settings.subtitle }}</p>
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</div>

