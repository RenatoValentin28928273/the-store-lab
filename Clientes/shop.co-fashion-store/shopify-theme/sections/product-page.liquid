<script>
(function() {
  var sid = '{{ section.id }}';
  var safeId = sid.replace(/-/g, '_');

  // -- Image gallery --
  var totalImages = {{ product.media.size | default: 0 }};
  var currentImageIdx = 0;
  window['pdpSetImage' + safeId] = function(idx) {
    currentImageIdx = idx;
    for (var i = 0; i < totalImages; i++) {
      var img = document.getElementById('pdp-img-' + sid + '-' + i);
      if (img) img.classList.toggle('opacity-0', i !== idx);
    }
    var thumbs = document.querySelectorAll('#pdp-thumbs-' + sid + ' .pdp-thumb');
    thumbs.forEach(function(t) { t.classList.toggle('active', parseInt(t.dataset.index) === idx); });
  };
  window['pdpPrev' + safeId] = function() {
    var idx = (currentImageIdx - 1 + totalImages) % totalImages;
    window['pdpSetImage' + safeId](idx);
  };
  window['pdpNext' + safeId] = function() {
    var idx = (currentImageIdx + 1) % totalImages;
    window['pdpSetImage' + safeId](idx);
  };

  // -- Quantity stepper --
  window['pdpChangeQty' + safeId] = function(delta) {
    var input = document.getElementById('pdp-qty-input-' + sid);
    var hidden = document.getElementById('pdp-quantity-hidden-' + sid);
    if (!input) return;
    var val = parseInt(input.value) + delta;
    if (val < 1) val = 1;
    if (val > 99) val = 99;
    input.value = val;
    if (hidden) hidden.value = val;
  };

  // -- Variant selection --
  var variants = {{ product.variants | json }};
  var selectedOptions = [
    '{{ first_variant.option1 | default: '' }}',
    '{{ first_variant.option2 | default: '' }}',
    '{{ first_variant.option3 | default: '' }}'
  ];

  function findVariant() {
    return variants.find(function(v) {
      return (v.option1 === selectedOptions[0] || !selectedOptions[0]) &&
             (v.option2 === selectedOptions[1] || !selectedOptions[1]) &&
             (v.option3 === selectedOptions[2] || !selectedOptions[2]);
    }) || variants[0];
  }

  function updateVariantUI() {
    var v = findVariant();
    if (!v) return;
    var vidInput = document.getElementById('pdp-variant-id-' + sid);
    if (vidInput) vidInput.value = v.id;

    var priceEl = document.getElementById('pdp-price-' + sid);
    if (priceEl) priceEl.textContent = formatMoney(v.price);

    var compareEl = document.getElementById('pdp-compare-price-' + sid);
    var badgeEl = document.getElementById('pdp-badge-' + sid);
    if (compareEl) {
      if (v.compare_at_price && v.compare_at_price > v.price) {
        compareEl.textContent = formatMoney(v.compare_at_price);
        compareEl.style.display = '';
        if (badgeEl) {
          var pct = Math.round((v.compare_at_price - v.price) * 100 / v.compare_at_price);
          badgeEl.textContent = '-' + pct + '%';
          badgeEl.style.display = '';
        }
      } else {
        compareEl.style.display = 'none';
        if (badgeEl) badgeEl.style.display = 'none';
      }
    }

    var atcBtn = document.getElementById('pdp-atc-btn-' + sid);
    if (atcBtn) {
      atcBtn.disabled = !v.available;
      atcBtn.textContent = v.available ? 'Add to Cart' : 'Sold Out';
    }
  }

  function formatMoney(cents) {
    var symbol = {{ shop.money_format | json }};
    return symbol.replace('{{amount}}', (cents / 100).toFixed(2))
                 .replace('{{amount_no_decimals}}', Math.round(cents / 100))
                 .replace('{{amount_with_comma_separator}}', (cents / 100).toFixed(2).replace('.', ','));
  }

  window['pdpSelectColor' + safeId] = function(btn) {
    var container = btn.closest('[id^="pdp-colors-"]');
    if (!container) return;
    container.querySelectorAll('.pdp-color-btn').forEach(function(b) { b.classList.remove('selected'); });
    btn.classList.add('selected');
    var optIdx = parseInt(container.dataset.optionIndex);
    selectedOptions[optIdx] = btn.dataset.value;
    updateVariantUI();
  };

  window['pdpSelectSize' + safeId] = function(btn) {
    var container = btn.closest('[id^="pdp-sizes-"]');
    if (!container) return;
    container.querySelectorAll('.pdp-size-btn').forEach(function(b) { b.classList.remove('selected'); });
    btn.classList.add('selected');
    var optIdx = parseInt(container.dataset.optionIndex);
    selectedOptions[optIdx] = btn.dataset.value;
    updateVariantUI();
  };

  // -- Tabs --
  window['pdpSwitchTab' + safeId] = function(btn, tabName) {
    document.querySelectorAll('#shopify-section-' + sid + ' .pdp-tab-btn').forEach(function(b) {
      b.classList.toggle('active', b.dataset.tab === tabName);
    });
    document.querySelectorAll('#shopify-section-' + sid + ' .pdp-tab-panel').forEach(function(panel) {
      panel.classList.add('hidden');
    });
    var target = document.getElementById('pdp-tab-' + tabName + '-' + sid);
    if (target) target.classList.remove('hidden');
  };

  // -- Reviews filter chips --
  window['pdpFilterReviews' + safeId] = function(btn, filter) {
    var wrap = document.getElementById('pdp-review-filters-' + sid);
    if (wrap) {
      wrap.querySelectorAll('.reviews-filter-chip').forEach(function(c) { c.classList.remove('active'); });
    }
    btn.classList.add('active');
    // Filter logic: for demo all cards remain visible; wire up real filter when using a reviews app
  };

  // -- Cart form AJAX --
  var form = document.getElementById('pdp-form-' + sid);
  if (form) {
    form.addEventListener('submit', function(e) {
      e.preventDefault();
      var btn = document.getElementById('pdp-atc-btn-' + sid);
      if (btn) { btn.textContent = 'Adding...'; btn.disabled = true; }
      var data = new FormData(form);
      fetch('/cart/add.js', {
        method: 'POST',
        body: data
      })
      .then(function(r) { return r.json(); })
      .then(function() {
        if (btn) { btn.textContent = 'Added!'; }
        setTimeout(function() {
          if (btn) { btn.textContent = 'Add to Cart'; btn.disabled = false; }
        }, 1500);
        fetch('/cart.js')
          .then(function(r) { return r.json(); })
          .then(function(cart) {
            var badges = document.querySelectorAll('[data-cart-count]');
            badges.forEach(function(b) { b.textContent = cart.item_count; });
          });
      })
      .catch(function() {
        if (btn) { btn.textContent = 'Error -- try again'; btn.disabled = false; }
      });
    });
  }

})();
</script>

