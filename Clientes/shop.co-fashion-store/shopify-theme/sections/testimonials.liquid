<section class="max-w-7xl mx-auto px-4 py-16 sm:py-24">
  <div class="flex items-center justify-between mb-12">
    <h2 class="text-3xl sm:text-5xl font-black tracking-tighter uppercase">{{ section.settings.title }}</h2>
  </div>
  
  <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
    {% for block in section.blocks %}
      <div class="border border-gray-100 rounded-[20px] p-8">
        <div class="flex text-yellow-400 mb-4">
          {% for i in (1..5) %}
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"></path></svg>
          {% endfor %}
        </div>
        <div class="flex items-center gap-1 mb-3">
          <h4 class="font-bold text-lg">{{ block.settings.author }}</h4>
          <div class="bg-green-500 rounded-full p-0.5">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="4" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
          </div>
        </div>
        <p class="text-gray-500 text-sm sm:text-base leading-relaxed">"{{ block.settings.text }}"</p>
      </div>
    {% endfor %}
  </div>
</section>

{% schema %}
{
  "name": "Testimonials",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "OUR HAPPY CUSTOMERS"
    }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Testimonial",
      "settings": [
        {
          "type": "text",
          "id": "author",
          "label": "Author Name",
          "default": "Sarah M."
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Testimonial Text",
          "default": "I'm blown away by the quality and style of the clothes I received from Shop.co."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Testimonials",
      "blocks": [
        { "type": "testimonial" },
        { "type": "testimonial" },
        { "type": "testimonial" }
      ]
    }
  ]
}
{% endschema %}
