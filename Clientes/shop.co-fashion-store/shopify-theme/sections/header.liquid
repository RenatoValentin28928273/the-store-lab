{% style %}
  :root {
    --header-font-color: {{ section.settings.font_color }};
    --header-font-size: {{ section.settings.font_size }}px;
  }

  {{ section.settings.font | font_face }}

  .header-nav-link {
    color: var(--header-font-color);
    font-size: var(--header-font-size);
    font-family: {{ section.settings.font.family }}, {{ section.settings.font.fallback_families }};
  }

  .header-logo-text {
    font-family: {{ section.settings.font.family }}, {{ section.settings.font.fallback_families }};
    color: var(--header-font-color);
  }

  {% if section.settings.sticky %}
    #shopify-section-{{ section.id }} {
      position: sticky;
      top: var(--announcement-height, 0);
      z-index: 100;
      background-color: white;
    }
  {% endif %}

  /* ── Mega menu wrapper ── */
  .nav-mega-wrapper {
    position: static;
  }

  /* ── Mega menu panel (full-width, anchored to nav bar) ── */
  .nav-mega-panel {
    position: fixed;
    top: var(--header-bottom, 80px);
    left: 0;
    right: 0;
    background: white;
    border-top: 1px solid #e5e7eb;
    border-bottom: 1px solid #e5e7eb;
    box-shadow: 0 12px 32px rgba(0,0,0,0.10);
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transition: opacity 0.2s ease, visibility 0.2s ease, transform 0.2s ease;
    transform: translateY(-8px);
    z-index: 200;
  }

  .nav-mega-wrapper:hover .nav-mega-panel,
  .nav-mega-wrapper:focus-within .nav-mega-panel {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
    transform: translateY(0);
  }

  .nav-mega-inner {
    max-width: 80rem;
    margin: 0 auto;
    padding: 32px 24px;
    display: flex;
    gap: 48px;
  }

  /* Left: link list */
  .nav-mega-links {
    min-width: 180px;
    flex-shrink: 0;
  }

  .nav-mega-links-title {
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #111;
    font-family: {{ section.settings.font.family }}, {{ section.settings.font.fallback_families }};
    margin-bottom: 16px;
    padding-bottom: 12px;
    border-bottom: 1px solid #e5e7eb;
  }

  .nav-mega-links a {
    display: block;
    padding: 7px 0;
    font-size: var(--header-font-size);
    color: #374151;
    font-family: {{ section.settings.font.family }}, {{ section.settings.font.fallback_families }};
    text-decoration: none;
    transition: color 0.12s;
  }

  .nav-mega-links a:hover {
    color: #000;
  }

  /* Right: featured image cards */
  .nav-mega-images {
    display: flex;
    gap: 16px;
    flex: 1;
  }

  .nav-mega-card {
    flex: 1;
    min-width: 0;
    text-decoration: none;
    color: inherit;
  }

  .nav-mega-card-img {
    width: 100%;
    aspect-ratio: 3/2;
    object-fit: cover;
    border-radius: 10px;
    display: block;
    background: #f3f4f6;
  }

  .nav-mega-card-label {
    margin-top: 10px;
    font-size: 14px;
    font-weight: 600;
    color: #111;
    font-family: {{ section.settings.font.family }}, {{ section.settings.font.fallback_families }};
  }

  /* Simple dropdown (links with no mega blocks configured) */
  .nav-dropdown-wrapper {
    position: relative;
  }

  .nav-dropdown-menu {
    position: absolute;
    top: calc(100% + 12px);
    left: 50%;
    transform: translateX(-50%) translateY(-6px);
    background: white;
    border: 1px solid #e5e7eb;
    border-radius: 12px;
    padding: 8px;
    min-width: 180px;
    box-shadow: 0 8px 24px rgba(0,0,0,0.10);
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transition: opacity 0.18s ease, transform 0.18s ease, visibility 0.18s;
    z-index: 200;
    white-space: nowrap;
  }

  .nav-dropdown-wrapper:hover .nav-dropdown-menu,
  .nav-dropdown-wrapper:focus-within .nav-dropdown-menu {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
    transform: translateX(-50%) translateY(0);
  }

  .nav-dropdown-menu a {
    display: block;
    padding: 8px 14px;
    border-radius: 8px;
    font-size: var(--header-font-size);
    color: var(--header-font-color);
    font-family: {{ section.settings.font.family }}, {{ section.settings.font.fallback_families }};
    text-decoration: none;
    transition: background 0.12s;
  }

  .nav-dropdown-menu a:hover {
    background: #f3f4f6;
  }

  .nav-dropdown-menu::before {
    content: '';
    position: absolute;
    top: -6px;
    left: 50%;
    transform: translateX(-50%);
    width: 12px;
    height: 12px;
    background: white;
    border-left: 1px solid #e5e7eb;
    border-top: 1px solid #e5e7eb;
    rotate: 45deg;
  }
{% endstyle %}

{%- comment -%}
  Build a map: menu_handle → blocks for that menu item (by nav_handle setting).
  Blocks of type "mega_image" attach to a specific nav link handle.
{%- endcomment -%}

<nav id="site-header-{{ section.id }}" class="max-w-7xl mx-auto px-4 py-6 flex items-center justify-between gap-4 sm:gap-12 bg-white">
  <div class="flex items-center gap-8 lg:gap-12">
    <a href="{{ routes.root_url }}" class="header-logo-text text-2xl sm:text-3xl font-black tracking-tighter uppercase whitespace-nowrap">
      {% if section.settings.logo != blank %}
        <img src="{{ section.settings.logo | image_url: width: 400 }}"
             alt="{{ shop.name | escape }}"
             width="{{ section.settings.logo.width | default: 400 }}"
             height="{{ section.settings.logo.height | default: 400 }}"
             style="height: {{ section.settings.logo_height }}px;"
             class="object-contain">
      {% else %}
        {{ shop.name | default: 'SHOP.CO' }}
      {% endif %}
    </a>

    <div class="hidden lg:flex items-center gap-6 font-medium">
      {% for link in linklists[section.settings.menu].links %}

        {%- comment -%} Collect mega_image blocks assigned to this link {%- endcomment -%}
        {%- assign link_handle = link.title | handleize -%}
        {%- assign has_mega_blocks = false -%}
        {%- for block in section.blocks -%}
          {%- if block.type == 'mega_image' and block.settings.nav_handle == link_handle -%}
            {%- assign has_mega_blocks = true -%}
            {%- break -%}
          {%- endif -%}
        {%- endfor -%}

        {% if link.links.size > 0 %}
          {%- comment -%} MEGA MENU — always for links with children {%- endcomment -%}
          <div class="nav-mega-wrapper">
            <a href="{{ link.url }}" class="header-nav-link flex items-center gap-1 hover:opacity-70 transition-opacity whitespace-nowrap">
              {{ link.title }}
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
            </a>
            <div class="nav-mega-panel">
              <div class="nav-mega-inner">
                <!-- Left: sublinks -->
                <div class="nav-mega-links">
                  <div class="nav-mega-links-title">{{ link.title }}</div>
                  {% for child_link in link.links %}
                    <a href="{{ child_link.url }}">{{ child_link.title }}</a>
                  {% endfor %}
                </div>
                <!-- Right: featured image cards (optional) -->
                {%- assign has_mega_blocks = false -%}
                {%- for block in section.blocks -%}
                  {%- if block.type == 'mega_image' and block.settings.nav_handle == link_handle -%}
                    {%- assign has_mega_blocks = true -%}
                    {%- break -%}
                  {%- endif -%}
                {%- endfor -%}
                {% if has_mega_blocks %}
                  <div class="nav-mega-images">
                    {%- for block in section.blocks -%}
                      {%- if block.type == 'mega_image' and block.settings.nav_handle == link_handle -%}
                        <a href="{{ block.settings.link }}" class="nav-mega-card" {{ block.shopify_attributes }}>
                          {% if block.settings.image != blank %}
                            <img
                              src="{{ block.settings.image | image_url: width: 600 }}"
                              alt="{{ block.settings.label | escape }}"
                              class="nav-mega-card-img"
                              loading="lazy"
                            >
                          {% else %}
                            <div class="nav-mega-card-img" style="background:#f3f4f6;"></div>
                          {% endif %}
                          {% if block.settings.label != blank %}
                            <div class="nav-mega-card-label">{{ block.settings.label }}</div>
                          {% endif %}
                        </a>
                      {%- endif -%}
                    {%- endfor -%}
                  </div>
                {% endif %}
              </div>
            </div>
          </div>

        {% else %}
          <a href="{{ link.url }}" class="header-nav-link flex items-center gap-1 hover:opacity-70 transition-opacity whitespace-nowrap">
            {{ link.title }}
          </a>
        {% endif %}

      {% endfor %}
    </div>
  </div>

  <div class="flex-1 max-w-lg hidden md:block">
    <div class="relative">
      <span class="absolute left-4 top-1/2 -translate-y-1/2 text-gray-400">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
      </span>
      <input
        type="text"
        placeholder="Search for products..."
        class="w-full bg-gray-100 rounded-full py-3 pl-12 pr-4 text-sm focus:outline-none focus:ring-1 focus:ring-black"
      >
    </div>
  </div>

  <div class="flex items-center gap-4" style="color: var(--header-font-color);">
    <button class="md:hidden">
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
    </button>
    <a href="{{ routes.cart_url }}" class="relative">
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="8" cy="21" r="1"/><circle cx="19" cy="21" r="1"/><path d="M2.05 2.05h2l2.66 12.42a2 2 0 0 0 2 1.58h9.78a2 2 0 0 0 1.95-1.57l1.65-7.43H5.12"/></svg>
      {% if cart.item_count > 0 %}
        <span class="absolute -top-1 -right-1 bg-black text-white text-[10px] w-4 h-4 rounded-full flex items-center justify-center">{{ cart.item_count }}</span>
      {% endif %}
    </a>
    <a href="{{ routes.account_url }}">
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="10" r="3"/><path d="M7 20.662V19a2 2 0 0 1 2-2h6a2 2 0 0 1 2 2v1.662"/></svg>
    </a>
  </div>
</nav>

<script>
  (function() {
    // Set --header-bottom CSS var so mega panels align precisely under the nav bar
    var nav = document.getElementById('site-header-{{ section.id }}');
    if (!nav) return;
    function updateHeaderBottom() {
      var rect = nav.getBoundingClientRect();
      // account for sticky offset
      var top = rect.bottom;
      document.documentElement.style.setProperty('--header-bottom', top + 'px');
    }
    updateHeaderBottom();
    window.addEventListener('scroll', updateHeaderBottom, { passive: true });
    window.addEventListener('resize', updateHeaderBottom, { passive: true });
  })();
</script>

{% schema %}
{
  "name": "Header",
  "settings": [
    {
      "type": "checkbox",
      "id": "sticky",
      "label": "Sticky Header",
      "default": false
    },
    {
      "type": "header",
      "content": "Logo"
    },
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo Image"
    },
    {
      "type": "range",
      "id": "logo_height",
      "min": 10,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Logo Height",
      "default": 24
    },
    {
      "type": "header",
      "content": "Navigation"
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Menu",
      "default": "main-menu"
    },
    {
      "type": "header",
      "content": "Typography & Colors"
    },
    {
      "type": "font_picker",
      "id": "font",
      "label": "Header Font",
      "default": "inter_n4"
    },
    {
      "type": "range",
      "id": "font_size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Font Size",
      "default": 14
    },
    {
      "type": "color",
      "id": "font_color",
      "label": "Font Color",
      "default": "#000000"
    }
  ],
  "blocks": [
    {
      "type": "mega_image",
      "name": "Mega Menu Image",
      "settings": [
        {
          "type": "text",
          "id": "nav_handle",
          "label": "Nav Link Handle",
          "info": "The handle (slug) of the parent nav link this image belongs to. E.g. if the link title is 'Collections', enter 'collections'."
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Featured Image"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Card Label"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Card Link"
        }
      ]
    }
  ]
}
{% endschema %}
