      padding-top: 22px;
      border-top: 1px solid rgb(var(--color-border-rgb) / 0.5);
      width: 100%;
    }

    .header-drawer--editorial .menu-drawer__secondary-item {
      display: block !important;
      text-decoration: none;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: var(--editorial-drawer-text-muted) !important;
      font-size: 1.05rem;
      line-height: 1.2;
      padding: 0.55rem 0;
    }

    .header-drawer--editorial .menu-drawer__utility-links {
      grid-column: 1;
      grid-row: 3;
      margin-top: auto;
      margin-bottom: 0;
      width: 100%;
    }

    .header-drawer--editorial .menu-drawer__footer {
      grid-column: 1;
      grid-row: 3;
      margin-top: auto;
      padding: 20px 34px max(26px, env(safe-area-inset-bottom, 0px));
      border-top: 0;
    }

    .header-drawer--editorial .menu-drawer__footer-link {
      font-size: var(--editorial-utility-size) !important;
      letter-spacing: var(--editorial-utility-spacing) !important;
      font-weight: var(--editorial-utility-weight) !important;
      color: var(--editorial-drawer-text-muted) !important;
      padding: 0.3rem 0;
      gap: 0.62rem;
    }

    .header-drawer--editorial .menu-drawer__footer-links {
      gap: 0.7rem;
      margin: 0;
    }

    .header-drawer--editorial .menu-drawer__footer .footer-icon svg {
      width: 14px;
      height: 14px;
    }

    .header-drawer--editorial .menu-drawer__footer .footer-icon {
      overflow: visible;
      flex-shrink: 0;
    }

    .header-drawer--editorial .menu-drawer__submenu {
      display: none !important;
    }

    .header-drawer--editorial .menu-drawer__menu-container[open] > .menu-drawer__submenu {
      display: none !important;
    }

    .header-drawer--editorial .menu-drawer__inner-submenu {
      margin: 0;
      padding: 56px 30px 24px;
      overflow-y: auto;
      height: 100%;
    }

    .header-drawer--editorial .menu-drawer__nav-buttons {
      display: none;
    }

    .header-drawer--editorial .menu-drawer__menu--childlist {
      display: none;
    }

    .header-drawer--editorial .menu-drawer__menu-item--parent {
      display: none;
    }

    .header-drawer--editorial .menu-drawer__menu--grandchildlist {
      display: none;
    }

    .header-drawer--editorial .menu-drawer__menu-item--child {
      display: none;
    }

    .header-drawer--editorial .menu-drawer__featured-content {
      display: none !important;
    }
  }
{% endstylesheet %}
