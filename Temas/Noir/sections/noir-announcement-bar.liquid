
{{ 'announcement-bar.js' | asset_url | script_tag }}

{%- style -%}
  .noir-announcement-bar {
    --bg-color: {{ section.settings.bg_color }};
    --text-color: {{ section.settings.text_color }};
    background-color: var(--bg-color);
    color: var(--text-color);
    overflow: hidden;
    position: relative;
    padding: {{ section.settings.padding_vertical }}px 0;
    font-family: var(--font-heading-family);
    text-transform: {{ section.settings.text_transform }};
    letter-spacing: {{ section.settings.letter_spacing }}px;
    font-size: {{ section.settings.font_size }}px;
    border-bottom: 1px solid rgba(255,255,255,0.1);
  }

  .noir-announcement-bar__content {
    display: flex;
    align-items: center;
    white-space: nowrap;
  }

  /* Marquee Effect */
  {% if section.settings.mode == 'marquee' %}
    .noir-announcement-bar__content {
      animation: noir-marquee {{ section.settings.speed }}s linear infinite;
      width: fit-content;
    }

    @keyframes noir-marquee {
      0% { transform: translateX(0); }
      100% { transform: translateX(-50%); }
    }
    
    .noir-announcement-item {
      display: inline-flex;
      align-items: center;
      padding: 0 {{ section.settings.gap_between }}px;
      animation: noir-fade-in 1s ease-out;
      text-shadow: 0 0 10px rgba(255,255,255,0.1);
    }

    @keyframes noir-fade-in {
      from { opacity: 0; transform: translateY(5px); }
      to { opacity: 1; transform: translateY(0); }
    }
  {% else %}
    /* Slider Mode */
    .noir-announcement-bar__content {
      justify-content: center;
      width: 100%;
    }
    .noir-announcement-item {
      display: none;
      text-align: center;
      animation: noir-slide-up 0.6s cubic-bezier(0.23, 1, 0.32, 1);
    }
    .noir-announcement-item.is-active {
      display: flex;
    }
    
    @keyframes noir-slide-up {
      from { opacity: 0; transform: translateY(10px); }
      to { opacity: 1; transform: translateY(0); }
    }
  {% endif %}

  .noir-announcement-item a {
    color: inherit;
    text-decoration: none;
    transition: opacity 0.3s ease;
  }

  .noir-announcement-item a:hover {
    opacity: 0.7;
  }

  .noir-announcement-dot {
    width: 6px;
    height: 6px;
    background-color: var(--text-color);
    border-radius: 50%;
    margin: 0 15px;
    display: inline-block;
    opacity: 0.5;
  }
{%- endstyle -%}

<div id="NoirAnnouncement-{{ section.id }}" class="noir-announcement-bar" role="region" aria-label="Announcements">
  <div class="noir-announcement-bar__content" {% if section.settings.mode == 'slider' %}data-noir-slider{% endif %}>
    {%- for block in section.blocks -%}
      <div class="noir-announcement-item {% if forloop.first %}is-active{% endif %}" {{ block.shopify_attributes }}>
        {%- if block.settings.link != blank -%}
          <a href="{{ block.settings.link }}">
        {%- endif -%}
          {{ block.settings.text }}
        {%- if block.settings.link != blank -%}
          </a>
        {%- endif -%}
        
        {% if section.settings.mode == 'marquee' %}
          <span class="noir-announcement-dot"></span>
        {% endif %}
      </div>
    {%- endfor -%}
    
    {%- comment -%} Duplicate for seamless marquee {%- endcomment -%}
    {% if section.settings.mode == 'marquee' %}
      {%- for block in section.blocks -%}
        <div class="noir-announcement-item" aria-hidden="true">
          {%- if block.settings.link != blank -%}
            <a href="{{ block.settings.link }}">
          {%- endif -%}
            {{ block.settings.text }}
          {%- if block.settings.link != blank -%}
            </a>
          {%- endif -%}
          <span class="noir-announcement-dot"></span>
        </div>
      {%- endfor -%}
    {% endif %}
  </div>
</div>

{% if section.settings.mode == 'slider' and section.blocks.size > 1 %}
<script>
  document.addEventListener('DOMContentLoaded', function() {
    const section = document.querySelector('#NoirAnnouncement-{{ section.id }}');
    const items = section.querySelectorAll('.noir-announcement-item');
    let current = 0;
    
    setInterval(() => {
      if (items.length > 0) {
        items[current].classList.remove('is-active');
        current = (current + 1) % items.length;
        items[current].classList.add('is-active');
      }
    }, {{ section.settings.speed | times: 1000 }});
  });
</script>
{% endif %}

{% schema %}
{
  "name": "Noir Announcement Bar",
  "enabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "select",
      "id": "mode",
      "label": "Display Mode",
      "options": [
        { "value": "marquee", "label": "Marquee (Scrolling)" },
        { "value": "slider", "label": "Slider" }
      ],
      "default": "marquee"
    },
    {
      "type": "range",
      "id": "speed",
      "min": 2,
      "max": 30,
      "step": 1,
      "unit": "s",
      "label": "Speed / Duration",
      "default": 15
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "font_size",
      "min": 10,
      "max": 20,
      "step": 1,
      "unit": "px",
      "label": "Font Size",
      "default": 12
    },
    {
      "type": "select",
      "id": "text_transform",
      "label": "Text Transform",
      "options": [
        { "value": "none", "label": "None" },
        { "value": "uppercase", "label": "Uppercase" },
        { "value": "lowercase", "label": "Lowercase" }
      ],
      "default": "uppercase"
    },
    {
      "type": "range",
      "id": "letter_spacing",
      "min": 0,
      "max": 5,
      "step": 0.5,
      "unit": "px",
      "label": "Letter Spacing",
      "default": 1.5
    },
    {
      "type": "range",
      "id": "padding_vertical",
      "min": 5,
      "max": 30,
      "step": 1,
      "unit": "px",
      "label": "Vertical Padding",
      "default": 10
    },
    {
      "type": "range",
      "id": "gap_between",
      "min": 10,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Gap between items (Marquee)",
      "default": 40
    }
  ],
  "blocks": [
    {
      "type": "announcement",
      "name": "Announcement",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Welcome to our store"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Noir Announcement Bar",
      "blocks": [
        { "type": "announcement", "settings": { "text": "Free shipping on orders over $50" } },
        { "type": "announcement", "settings": { "text": "New collection out now" } },
        { "type": "announcement", "settings": { "text": "Follow us on Instagram @noir" } }
      ]
    }
  ]
}
{% endschema %}
