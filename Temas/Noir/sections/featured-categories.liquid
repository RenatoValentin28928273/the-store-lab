      "max": 6,
      "step": 1,
      "label": "Colunas no Desktop",
      "default": 5
    },
    {
      "type": "header",
      "content": "Headline (Título Superior)"
    },
    {
      "type": "text",
      "id": "headline",
      "label": "Headline",
      "default": "Headline"
    },
    {
      "type": "font_picker",
      "id": "font_family",
      "label": "Fonte da Headline",
      "default": "helvetica_n4"
    },
    {
      "type": "color",
      "id": "headline_color",
      "label": "Cor da Headline",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "headline_size",
      "min": 20,
      "max": 80,
      "step": 2,
      "unit": "px",
      "label": "Tamanho da Headline",
      "default": 32
    },
    {
      "type": "header",
      "content": "Subtext (Título Superior)"
    },
    {
      "type": "text",
      "id": "subtext",
      "label": "Subtext",
      "default": "Subtext"
    },
    {
      "type": "font_picker",
      "id": "subtext_font_family",
      "label": "Fonte do Subtext",
      "default": "helvetica_n4"
    },
    {
      "type": "color",
      "id": "subtext_color",
      "label": "Cor do Subtext",
      "default": "#666666"
    },
    {
      "type": "range",
      "id": "subtext_size",
      "min": 10,
      "max": 30,
      "step": 1,
      "unit": "px",
      "label": "Tamanho do Subtext",
      "default": 14
    }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Categoria",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Imagem da Categoria"
        },
        {
          "type": "header",
          "content": "Estilo do Nome da Categoria"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Nome da Categoria",
          "default": "Category"
        },
        {
          "type": "font_picker",
          "id": "title_font",
          "label": "Fonte do Nome",
          "default": "helvetica_n4"
        },
        {
          "type": "color",
          "id": "title_color",
          "label": "Cor do Nome",
          "default": "#000000"
        },
        {
          "type": "range",
          "id": "title_size",
          "min": 12,
          "max": 40,
          "step": 1,
          "unit": "px",
          "label": "Tamanho do Nome",
          "default": 18
        },
        {
          "type": "header",
          "content": "Estilo do Subtext da Categoria"
        },
        {
          "type": "text",
          "id": "subtext",
          "label": "Subtext",
          "default": "Subtext"
        },
        {
          "type": "font_picker",
          "id": "subtext_font",
          "label": "Fonte do Subtext",
          "default": "helvetica_n4"
        },
        {
          "type": "color",
          "id": "subtext_color",
          "label": "Cor do Subtext",
          "default": "#666666"
        },
        {
          "type": "range",
          "id": "subtext_size",
          "min": 10,
          "max": 24,
          "step": 1,
          "unit": "px",
          "label": "Tamanho do Subtext",
          "default": 12
        },
        {
          "type": "header",
          "content": "Botão CTA (Call to Action)"
        },
        {
          "type": "text",
          "id": "cta_text",
          "label": "Texto do Link",
          "default": "SHOP NOW"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link do Card"
        },
        {
          "type": "color",
          "id": "cta_color",
          "label": "Cor do Link",
          "default": "#FFFFFF"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Categorias Noir",
      "blocks": [
        { "type": "category" },
        { "type": "category" },
        { "type": "category" },
        { "type": "category" },
        { "type": "category" }
