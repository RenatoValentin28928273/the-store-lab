<section class="store-benefits">
  <div class="benefits-inner">
    {% if section.blocks.size > 0 %}
      {% for block in section.blocks %}
        <div class="benefit-item" {{ block.shopify_attributes }}>
          <div class="benefit-icon">
            {{ block.settings.custom_svg }}
          </div>
          <span class="benefit-text">{{ block.settings.title }}</span>
        </div>
      {% endfor %}
    {% else %}
        <!-- Defaults if no blocks added -->
        <div class="benefit-item">
            <div class="benefit-icon">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"></path><polyline points="3.27 6.96 12 12.01 20.73 6.96"></polyline><line x1="12" y1="22.08" x2="12" y2="12"></line></svg>
            </div>
            <span class="benefit-text">Entrega rápida</span>
        </div>
        <div class="benefit-item">
            <div class="benefit-icon">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M17 2l4 4-4 4M3 11V9a4 4 0 0 1 4-4h14M7 22l-4-4 4-4M21 13v2a4 4 0 0 1-4 4H3"/></svg>
            </div>
            <span class="benefit-text">Troca grátis</span>
        </div>
        <div class="benefit-item">
            <div class="benefit-icon">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l2.4 7.6L22 12l-7.6 2.4L12 22l-2.4-7.6L2 12l7.6-2.4z"/></svg>
            </div>
            <span class="benefit-text">Qualidade</span>
        </div>
        <div class="benefit-item">
            <div class="benefit-icon">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 2L2 12l10 10 10-10L12 2z"/></svg>
            </div>
            <span class="benefit-text">Atendimento</span>
        </div>
    {% endif %}
  </div>
</section>

<style>
.store-benefits {
    background-color: #fff;
    padding: 32px 40px;
    border-bottom: 1px solid var(--border-color);
}

.benefits-inner {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 8vh;
    flex-wrap: wrap;
    max-width: 1400px;
    margin: 0 auto;
}

@media (min-width: 1024px) {
    .benefits-inner {
        gap: 120px;
    }
}

.benefit-item {
    display: flex;
    align-items: center;
    gap: 12px;
}

.benefit-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-black);
}

.benefit-text {
    font-size: 13px;
    font-weight: 500;
    color: var(--color-black);
    letter-spacing: 0.02em;
}
</style>

{% schema %}
{
  "name": "Benefícios da Loja",
  "settings": [],
  "blocks": [
    {
      "type": "benefit",
      "name": "Benefício",
      "limit": 4,
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Texto do Benefício"
        },
        {
          "type": "html",
          "id": "custom_svg",
          "label": "SVG do Ícone (Opcional)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Benefícios da Loja",
      "blocks": [
        { "type": "benefit" },
        { "type": "benefit" },
        { "type": "benefit" },
        { "type": "benefit" }
      ]
    }
  ]
}
{% endschema %}
