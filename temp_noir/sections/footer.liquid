<footer class="footer">
  <div class="container">
    <div class="footer-top">
      <div class="footer-newsletter">
        <h3 class="newsletter-title">{{ section.settings.newsletter_title | default: 'Entre para o clube.' }}</h3>
        <p class="newsletter-text">{{ section.settings.newsletter_text | default: 'Receba curadorias exclusivas e lançamentos antecipados.' }}</p>
        <form class="newsletter-form">
          <input type="email" placeholder="Seu melhor e-mail..." class="newsletter-input">
          <button type="submit" class="newsletter-btn">ENTRAR</button>
        </form>
      </div>
      
      <div class="footer-grid">
        <div class="footer-col">
          <h4 class="footer-label">INSTITUCIONAL</h4>
          <ul class="footer-links">
            <li><a href="#">Nossa História</a></li>
            <li><a href="#">Sustentabilidade</a></li>
            <li><a href="#">Ondere encontrar</a></li>
          </ul>
        </div>
        <div class="footer-col">
          <h4 class="footer-label">AJUDA</h4>
          <ul class="footer-links">
            <li><a href="#">FAQ</a></li>
            <li><a href="#">Envio & Entrega</a></li>
            <li><a href="#">Trocas & Devoluções</a></li>
          </ul>
        </div>
      </div>
    </div>

    <div class="footer-bottom">
      <div class="footer-logo">NOIR</div>
      <div class="footer-info">
        <span class="copyright">© {{ 'now' | date: '%Y' }} Noir. Todos os direitos reservados.</span>
        <div class="payment-methods">
          <span class="payment-item">VISA</span>
          <span class="payment-item">MASTER</span>
          <span class="payment-item">PIX</span>
        </div>
      </div>
    </div>
  </div>
</footer>

<style>
.footer {
    background-color: var(--color-dark-gray);
    color: var(--color-off-white);
    padding: 100px 0 40px;
    margin-top: 0;
}

.footer-top {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 100px;
    padding-bottom: 80px;
    border-bottom: 1px solid rgba(255,255,255,0.05);
}

.newsletter-title {
    font-size: 24px;
    font-weight: 300;
    margin-bottom: 16px;
}

.newsletter-text {
    font-size: 13px;
    color: var(--color-gray);
    margin-bottom: 30px;
}

.newsletter-form {
    display: flex;
    max-width: 480px;
    border-bottom: 1px solid var(--color-gray);
}

.newsletter-input {
    flex: 1;
    background: transparent;
    border: none;
    color: #fff;
    padding: 12px 0;
    font-size: 14px;
    outline: none;
}

.newsletter-btn {
    background: transparent;
    border: none;
    color: #fff;
    font-size: 11px;
    letter-spacing: 0.1em;
    cursor: pointer;
    font-weight: 700;
}

.footer-grid {
    display: flex;
    gap: 80px;
}

.footer-label {
    font-size: 10px;
    letter-spacing: 0.2em;
    color: var(--color-accent);
    margin-bottom: 24px;
}

.footer-links {
    list-style: none;
}

.footer-links li {
    margin-bottom: 12px;
}

.footer-links a {
    font-size: 12px;
    color: var(--color-gray);
    transition: color 0.3s;
}

.footer-links a:hover {
    color: #fff;
}

.footer-bottom {
    padding-top: 40px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 40px;
}

.footer-logo {
    font-size: 24px;
    font-weight: 700;
    letter-spacing: 0.3em;
}

.footer-info {
    width: 100%;
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 10px;
    color: var(--color-mid-gray);
    letter-spacing: 0.05em;
}

.payment-methods {
    display: flex;
    gap: 16px;
}

.payment-item {
    opacity: 0.5;
}

@media (max-width: 768px) {
    .footer-top {
        grid-template-columns: 1fr;
        gap: 60px;
    }
    .footer-grid {
        gap: 40px;
    }
}
</style>

{% schema %}
{
  "name": "Footer Noir",
  "settings": [
    {
      "type": "text",
      "id": "newsletter_title",
      "label": "Título Newsletter",
      "default": "Entre para o clube."
    }
  ]
}
{% endschema %}
