{% comment %}
  Footer Noir Premium - Com controles de Tipografia
{% endcomment %}

{%- style -%}
  /* Carregamento das fontes escolhidas no editor */
  {{ section.settings.font_logo | font_face: font_display: 'swap' }}
  {{ section.settings.font_content | font_face: font_display: 'swap' }}

  .footer-noir {
    background-color: {{ section.settings.bg_color }};
    color: {{ section.settings.text_color }};
    padding: 80px 0 40px;
    font-family: {{ section.settings.font_content.family }}, {{ section.settings.font_content.fallback_families }};
  }

  .footer-noir a {
    color: inherit;
    text-decoration: none;
    transition: opacity 0.3s ease;
  }

  .footer-noir a:hover {
    opacity: 0.7;
  }

  .footer-noir__container {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 40px;
  }

  .footer-noir__grid {
    display: grid;
    grid-template-columns: 1.5fr 1fr 1fr;
    gap: 60px;
    margin-bottom: 80px;
  }

  .footer-noir__brand-col {
    display: flex;
    flex-direction: column;
    gap: 40px;
  }

  /* Estilo da Logo Dinâmica */
  .footer-noir__logo {
    font-family: {{ section.settings.font_logo.family }}, {{ section.settings.font_logo.fallback_families }};
    font-size: {{ section.settings.logo_size }}px;
    font-weight: {{ section.settings.font_logo.weight }};
    font-style: {{ section.settings.font_logo.style }};
    margin: 0;
    line-height: 1;
    color: {{ section.settings.accent_color }};
  }

  .footer-noir__newsletter-text {
    font-size: {{ section.settings.newsletter_size }}px;
    margin-bottom: 20px;
    font-weight: 500;
  }

  .footer-noir__form {
    display: flex;
    position: relative;
    max-width: 400px;
    border-bottom: 1px solid {{ section.settings.accent_color }};
  }

  .footer-noir__input {
    flex: 1;
    background: transparent;
    border: none;
    padding: 12px 0;
    font-size: 14px;
    color: {{ section.settings.text_color }};
    outline: none;
  }

  .footer-noir__submit {
    background: transparent;
    border: none;
    color: {{ section.settings.accent_color }};
    font-weight: 700;
    text-transform: uppercase;
    font-size: 13px;
    cursor: pointer;
    padding: 0 0 0 15px;
    letter-spacing: 0.05em;
  }

  .footer-noir__socials {
    display: flex;
    gap: 20px;
    margin-top: 10px;
  }

  .footer-noir__social-link svg {
    width: 20px;
    height: 20px;
    fill: {{ section.settings.accent_color }};
  }

  /* Estilo dos Rótulos Dinâmicos */
  .footer-noir__label {
    font-size: {{ section.settings.label_size }}px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 30px;
    display: block;
  }

  .footer-noir__list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .footer-noir__list li {
    margin-bottom: 12px;
  }

  .footer-noir__list a {
    font-size: 14px;
    font-weight: 400;
  }

  .footer-noir__bottom {
    border-top: 1px solid rgba(161, 90, 77, 0.1);
    padding-top: 30px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 30px;
  }

  .footer-noir__payments {
    display: flex;
    gap: 15px;
    justify-content: center;
  }

  .footer-noir__payment-icon {
    width: 38px;
    height: auto;
  }

  .footer-noir__legal {
    display: flex;
    gap: 25px;
    justify-content: center;
    font-size: 11px;
    opacity: 0.8;
  }

  .footer-noir__copyright {
    font-size: 11px;
    opacity: 0.8;
    text-align: center;
  }

  @media (max-width: 992px) {
    .footer-noir__grid { grid-template-columns: 1fr; gap: 50px; }
    .footer-noir__brand-col { align-items: center; text-align: center; }
    .footer-noir__form { margin: 0 auto; width: 100%; }
    .footer-noir__col--links { display: grid; grid-template-columns: repeat(2, 1fr); text-align: left; }
  }
  @media (max-width: 768px) {
    .footer-noir__col--links { grid-template-columns: 1fr; gap: 40px; }
    .footer-noir__logo { font-size: calc({{ section.settings.logo_size }}px * 0.8); }
  }
{%- endstyle -%}

<footer class="footer-noir" id="section-{{ section.id }}">
  <div class="footer-noir__container">
    <div class="footer-noir__grid">
      <div class="footer-noir__brand-col">
        <div class="footer-noir__header">
          <h2 class="footer-noir__logo">{{ section.settings.brand_name }}</h2>
          <div class="footer-noir__socials">
            {%- if settings.social_facebook_link != blank -%}
              <a href="{{ settings.social_facebook_link }}" class="footer-noir__social-link">
                <svg viewBox="0 0 24 24"><path d="M18.77,7.46H14.5v-1.9c0-.9.6-1.1,1-1.1h3V.33h-4.14c-4.59,0-5.63,3.43-5.63,5.63v1.5H5.86v4.89h2.87v11.29h4.77v-11.29h4.13l.77-4.89Z"/></svg>
              </a>
            {%- endif -%}
            {%- if settings.social_instagram_link != blank -%}
              <a href="{{ settings.social_instagram_link }}" class="footer-noir__social-link">
                <svg viewBox="0 0 24 24"><path d="M12,2.16c3.2,0,3.58.01,4.85.07,1.17.05,1.81.25,2.23.41.56.22.95.48,1.37.9.42.42.68.81.9,1.37.16.42.36,1.05.41,2.23.06,1.27.07,1.65.07,4.85s-.01,3.58-.07,4.85c-.05,1.17-.25,1.81-.41,2.23-.22.56-.48.95-.9,1.37-.42.42-.81.68-1.37.9-.42.16-1.05.36-2.23.41-1.27.06-1.65.07-4.85.07s-3.58-.01-4.85-.07c-1.17-.05-1.81-.25-2.23-.41-.56-.22-.95-.48-1.37-.9-.42-.42-.68-.81-.9-1.37-.16-.42-.36-1.05-.41-2.23-.06-1.27-.07-1.65-.07-4.85s.01-3.58.07-4.85c.05-1.17.25-1.81.41-2.23.22-.56.48-.95.9-1.37.42-.42.81-.68,1.37-.9.42-.16,1.05-.36,2.23-.41,1.27-.06,1.65-.07,4.85-.07M12,0C8.74,0,8.33.01,7.05.07,5.77.13,4.9.33,4.14.62c-.78.3-1.45.71-2.11,1.37C1.37,2.65.96,3.32.66,4.1c-.29.77-.49,1.63-.55,2.91C0,8.3,0,8.71,0,12s.01,3.7.07,4.98c.06,1.28.26,2.14.55,2.91.3.78.71,1.45,1.37,2.11.66.66,1.33,1.07,2.11,1.37.77.29,1.63.49,2.91.55,1.28.06,1.69.07,4.98.07s3.7-.01,4.98-.07c1.28-.06,2.14-.26,2.91-.55.78-.3,1.45-.71,2.11-1.37.66-.66,1.07-1.33,1.37-2.11.29-.77.49-1.63.55-2.91.06-1.28.07-1.69.07-4.98s-.01-3.7-.07-4.98c-.06-1.28-.26-2.14-.55-2.91-.3-.78-.71-1.45-1.37-2.11-.66-.66-1.33-1.07-2.11-1.37-.77-.29-1.63-.49-2.91-.55C15.67.01,15.26,0,12,0Z"/><path d="M12,5.84A6.16,6.16,0,1,0,18.16,12,6.16,6.16,0,0,0,12,5.84Zm0,10.16A4,4,0,1,1,16,12,4,4,0,0,1,12,16Z"/><circle cx="18.41" cy="5.59" r="1.44"/></svg>
              </a>
            {%- endif -%}
          </div>
        </div>

        <div class="footer-noir__newsletter">
          <p class="footer-noir__newsletter-text">{{ section.settings.newsletter_title }}</p>
          {%- form 'customer', id: 'ContactFooter', class: 'footer-noir__form' -%}
            <input type="hidden" name="contact[tags]" value="newsletter">
            <input
              id="NewsletterForm--{{ section.id }}"
              type="email"
              name="contact[email]"
              class="footer-noir__input"
              value="{{ form.email }}"
              placeholder="youremail@example.com"
              required
            >
            <button type="submit" class="footer-noir__submit" name="commit">Submit</button>
          {%- endform -%}
        </div>
      </div>

      {%- for block in section.blocks -%}
        <div class="footer-noir__col footer-noir__col--nav" {{ block.shopify_attributes }}>
          {%- if block.settings.title != blank -%}
            <span class="footer-noir__label">{{ block.settings.title }}</span>
          {%- endif -%}
          {%- if block.settings.menu != blank -%}
            <ul class="footer-noir__list">
              {%- for link in block.settings.menu.links -%}
                <li><a href="{{ link.url }}">{{ link.title }}</a></li>
              {%- endfor -%}
            </ul>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>

    <div class="footer-noir__bottom">
      {%- if section.settings.show_payment_icons -%}
        <div class="footer-noir__payments">
          {%- for type in shop.enabled_payment_types -%}
            {{ type | payment_type_svg_tag: class: 'footer-noir__payment-icon' }}
          {%- endfor -%}
        </div>
      {%- endif -%}
      <div class="footer-noir__legal">
        {%- if section.settings.bottom_menu != blank -%}
          {%- for link in section.settings.bottom_menu.links -%}
            <a href="{{ link.url }}">{{ link.title }}</a>
          {%- endfor -%}
        {%- endif -%}
      </div>
      <div class="footer-noir__copyright">
        &copy; {{ 'now' | date: "%Y" }} {{ section.settings.brand_name }}. Todos os direitos reservados.
      </div>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer Premium noir",
  "settings": [
    {
      "type": "text",
      "id": "brand_name",
      "label": "Nome da Marca",
      "default": "Andie"
    },
    {
      "type": "header",
      "content": "Tipografia da Logo"
    },
    {
      "type": "font_picker",
      "id": "font_logo",
      "label": "Fonte da Logo",
      "default": "playfair_display_n7"
    },
    {
      "type": "range",
      "id": "logo_size",
      "min": 24,
      "max": 80,
      "step": 2,
      "unit": "px",
      "label": "Tamanho da Logo",
      "default": 48
    },
    {
      "type": "header",
      "content": "Tipografia Geral"
    },
    {
      "type": "font_picker",
      "id": "font_content",
      "label": "Fonte do Conteúdo",
      "default": "inter_n4"
    },
    {
      "type": "range",
      "id": "newsletter_size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Tamanho do Texto Newsletter",
      "default": 16
    },
    {
      "type": "range",
      "id": "label_size",
      "min": 10,
      "max": 20,
      "step": 1,
      "unit": "px",
      "label": "Tamanho do Título das Colunas",
      "default": 13
    },
    {
      "type": "header",
      "content": "Newsletter"
    },
    {
      "type": "text",
      "id": "newsletter_title",
      "label": "Título da Newsletter",
      "default": "Stay updated on the latest from Andie"
    },
    {
      "type": "header",
      "content": "Cores"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Cor de Fundo",
      "default": "#f4ece1"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Cor do Texto",
      "default": "#a15a4d"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Cor de Destaque",
      "default": "#a15a4d"
    },
    {
      "type": "header",
      "content": "Rodapé Inferior"
    },
    {
      "type": "checkbox",
      "id": "show_payment_icons",
      "label": "Mostrar ícones de pagamento",
      "default": true
    },
    {
      "type": "link_list",
      "id": "bottom_menu",
      "label": "Menu Inferior (Legal)"
    }
  ],
  "blocks": [
    {
      "type": "menu",
      "name": "Menu de Links",
      "limit": 3,
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Título da Coluna",
          "default": "Support"
        },
        {
          "type": "link_list",
          "id": "menu",
          "label": "Selecionar Menu"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Footer Premium noir",
      "blocks": [
        { "type": "menu", "settings": { "title": "Support" } },
        { "type": "menu", "settings": { "title": "Company" } }
      ]
    }
  ]
}
{% endschema %}
