{%- comment -%} Limpeza de Cache - Versão Final v2 {%- endcomment -%}
{%- style -%}
  {%- if section.settings.title_font != blank -%}
    {{ section.settings.title_font | font_face: font_display: 'swap' }}
  {%- endif -%}

  {%- comment -%} Carrega fontes das sub-coleções {%- endcomment -%}
  {%- for block in section.blocks -%}
    {%- if block.settings.title_font != blank -%}
      {{ block.settings.title_font | font_face: font_display: 'swap' }}
    {%- endif -%}
  {%- endfor -%}

  .list-collections-noir {
    padding: 60px 0;
    background-color: {{ section.settings.section_bg_color | default: '#ffffff' }};
  }
  .list-collections-noir__header {
    max-width: 800px;
    margin-bottom: 60px;
  }
  .list-collections-noir__title {
    font-family: {% if section.settings.title_font != blank %}{{ section.settings.title_font.family }}, {{ section.settings.title_font.fallback_families }}{% else %}serif{% endif %};
    font-size: {{ section.settings.title_size }}px;
    color: {{ section.settings.title_color }};
    line-height: 1.1;
    margin-bottom: 20px;
  }
  .list-collections-noir__description {
    font-size: {{ section.settings.desc_size }}px;
    color: {{ section.settings.desc_color }};
    line-height: 1.6;
    margin-bottom: 25px;
  }
  .list-collections-noir__count {
    font-size: 13px;
    color: #888;
    margin-top: 40px;
    letter-spacing: 0.05em;
  }
  
  /* Filtros Horizontais */
  .list-collections-noir__filters {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 40px;
    margin-bottom: 60px;
    padding-bottom: 5px;
  }
  .list-collections-noir__filter-item {
    display: inline-block;
    padding: 12px 30px;
    border: 1px solid #000;
    background-color: #fff;
    text-align: center;
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.15em;
    text-decoration: none;
    color: #000;
    transition: all 0.2s ease;
  }
  .list-collections-noir__filter-item:hover {
    border-color: #000;
    background: #000;
    color: #fff;
  }

  /* Subcategoria Row */
  .collection-row {
    margin-bottom: 80px;
  }
  .collection-row__header {
    padding: 20px;
    text-align: center;
    margin-bottom: 30px;
  }
  .collection-row__title {
    margin: 0;
  }
  .collection-row__subtext {
    font-size: 12px;
    text-transform: lowercase;
    display: block;
    margin-top: 5px;
    opacity: 0.8;
  }

  /* Navegação do Carousel */
  .list-collections-noir .collection-row__nav {
    position: absolute !important;
    top: 50% !important;
    left: 0 !important;
    right: 0 !important;
    transform: translateY(-50%) !important;
    display: flex !important;
    justify-content: space-between !important;
    padding: 0 5px !important;
    z-index: 20 !important;
    pointer-events: none !important;
  }
  .list-collections-noir .collection-row__button {
    pointer-events: auto !important;
    background: #ffffff !important;
    border: 1px solid #000000 !important;
    width: 48px !important;
    height: 48px !important;
    border-radius: 50% !important;
    display: flex !important;
    align-items: center !important;
    justify-content: center !important;
    cursor: pointer !important;
    transition: all 0.3s ease-in-out !important;
    color: #000000 !important;
    padding: 0 !important;
    box-shadow: 0 4px 15px rgba(0,0,0,0.15) !important;
  }
  .list-collections-noir .collection-row__button:hover {
    background: #000000 !important;
    color: #ffffff !important;
    transform: scale(1.1) !important;
  }
  .list-collections-noir .collection-row__button.prev { margin-left: 5px !important; }
  .list-collections-noir .collection-row__button.next { margin-right: 5px !important; }
  .list-collections-noir .collection-row__button svg {
    width: 20px !important;
    height: 20px !important;
  }

  .row-carousel-container {
    position: relative !important;
    padding: 0 40px !important; /* Espaço para as setas não ficarem em cima do produto */
  }
  .row-carousel {
    display: flex;
    gap: 20px;
    padding: 0 22px;
    overflow-x: auto;
    scroll-behavior: smooth;
    -ms-overflow-style: none; /* Internet Explorer 10+ */
    scrollbar-width: none; /* Firefox */
  }
  .row-carousel::-webkit-scrollbar {
    display: none; /* Safari and Chrome */
  }
  .row-carousel__item {
    flex: 0 0 calc(20% - 16px);
    min-width: 200px;
  }

  .collection-row__footer {
    text-align: center;
    margin-top: 30px;
  }
  .collection-row__view-all {
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #000;
    text-decoration: underline;
  }

  @media (max-width: 1024px) {
    .row-carousel__item {
      flex: 0 0 calc(33.33% - 14px);
    }
  }
  @media (max-width: 768px) {
    .row-carousel__item {
      flex: 0 0 70%;
    }
    .row-carousel {
      overflow-x: auto;
      scroll-snap-type: x mandatory;
    }
    .row-carousel__item {
      scroll-snap-align: start;
    }
    .list-collections-noir__title {
      font-size: 2.5rem;
    }
  }
{%- endstyle -%}

<div class="list-collections-noir section-{{ section.id }}">
  <div class="container">
    
    {%- liquid
      assign display_title = section.settings.title
      assign display_description = section.settings.description
      
      if template.name == 'collection' and collection
        assign display_title = collection.title
        if collection.description != blank
          assign display_description = collection.description
        endif
      endif

      # Lógica de Contagem: Se a coleção pai estiver zerada, somamos os blocos
      assign total_products = collection.all_products_count | default: 0
      if total_products == 0
        for block in section.blocks
          if block.settings.collection != blank
            assign total_products = total_products | plus: block.settings.collection.all_products_count
          endif
        endfor
      endif
    -%}

    <!-- Cabeçalho do Departamento -->
    <header class="list-collections-noir__header">
      <{{ section.settings.heading_tag | default: 'h1' }} class="list-collections-noir__title">{{ display_title }}</{{ section.settings.heading_tag | default: 'h1' }}>
      
      {% if display_description != blank %}
        <div class="list-collections-noir__description">
          {{ display_description }}
        </div>
      {% endif %}
      
      <div class="list-collections-noir__count">
        {{ total_products }} {% if total_products == 1 %}Produto{% else %}Produtos{% endif %}
      </div>
    </header>

    <!-- Barra de Filtros (Links Rápidos) -->
    <nav class="list-collections-noir__filters">
      {% for block in section.blocks %}
        {%- if block.settings.collection != blank -%}
          <a href="#collection-{{ block.id }}" class="list-collections-noir__filter-item">
            {{ block.settings.title | default: block.settings.collection.title | upcase }}
          </a>
        {%- endif -%}
      {% endfor %}
    </nav>

    <!-- Listagem das Coleções -->
    <div class="list-collections-noir__rows">
      {% for block in section.blocks %}
        {%- assign collection = block.settings.collection -%}
        {%- if collection != blank -%}
          <div class="collection-row" id="collection-{{ block.id }}" {{ block.shopify_attributes }}>
            
            <div class="collection-row__header" style="background-color: {{ block.settings.bg_color | default: '#f4f4f4' }};">
              {%- assign block_font = block.settings.title_font | default: section.settings.title_font -%}
              <{{ block.settings.heading_tag | default: 'h2' }} class="collection-row__title" style="
                font-family: {% if block_font != blank %}{{ block_font.family }}, {{ block_font.fallback_families }}{% else %}serif{% endif %};
                font-weight: {{ block_font.weight | default: 500 }};
                font-style: {{ block_font.style | default: 'normal' }};
                font-size: {{ block.settings.title_size }}px; 
                color: {{ block.settings.title_color }};
              ">
                {{ block.settings.title | default: collection.title }}
              </{{ block.settings.heading_tag | default: 'h2' }}>
              {% if block.settings.subtext != blank %}
                <span class="collection-row__subtext" style="color: {{ block.settings.title_color }};">{{ block.settings.subtext }}</span>
              {% endif %}
            </div>

            <div class="row-carousel-container">
              <div class="collection-row__nav">
                <button class="collection-row__button prev" aria-label="Anterior">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M15 18l-6-6 6-6"/></svg>
                </button>
                <button class="collection-row__button next" aria-label="Próximo">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M9 18l6-6-6-6"/></svg>
                </button>
              </div>
              <div class="row-carousel">
                {% for product in collection.products limit: 10 %}
                  <div class="row-carousel__item">
                    {% render 'product-card-noir', product: product %}
                  </div>
                {% endfor %}
              </div>
            </div>

            <div class="collection-row__footer">
              <a href="{{ collection.url }}" class="collection-row__view-all">Ver todos</a>
            </div>
          </div>
        {%- endif -%}
      {% endfor %}
    </div>

  </div>
</div>

{% schema %}
{
  "name": "Departamento Noir",
  "settings": [
    {
      "type": "header",
      "content": "Estilo da Seção"
    },
    {
      "type": "color",
      "id": "section_bg_color",
      "label": "Cor de Fundo da Seção",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "SEO e Títulos"
    },
    {
      "type": "select",
      "id": "heading_tag",
      "label": "Tag de Título (SEO)",
      "options": [
        { "value": "h1", "label": "H1" },
        { "value": "h2", "label": "H2" }
      ],
      "default": "h1"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Título do Departamento",
      "default": "Roupas (Departamento)"
    },
    {
      "type": "font_picker",
      "id": "title_font",
      "label": "Fonte do Título",
      "default": "helvetica_n4"
    },
    {
      "type": "range",
      "id": "title_size",
      "min": 20,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Tamanho do Título",
      "default": 56
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Cor do Título",
      "default": "#000000"
    },
    {
      "type": "header",
      "content": "Descrição"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Descrição SEO",
      "default": "<p>Introdução com até 1000 caracteres trabalhando a palavra-chave principal no início e com um CTA.</p>"
    },
    {
      "type": "range",
      "id": "desc_size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Tamanho da Descrição",
      "default": 16
    },
    {
      "type": "color",
      "id": "desc_color",
      "label": "Cor da Descrição",
      "default": "#666666"
    },
    {
      "type": "header",
      "content": "Barra de Filtros"
    },
    {
      "type": "color",
      "id": "filter_bg_color",
      "label": "Cor de Fundo dos Filtros",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "filter_text_color",
      "label": "Cor do Texto/Borda dos Filtros",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "filter_font_size",
      "min": 10,
      "max": 20,
      "step": 1,
      "unit": "px",
      "label": "Tamanho da Fonte dos Filtros",
      "default": 11
    }
  ],
  "blocks": [
    {
      "type": "collection_row",
      "name": "Sub-coleção",
      "settings": [
        {
          "type": "header",
          "content": "Conteúdo"
        },
        {
          "type": "collection",
          "id": "collection",
          "label": "Coleção"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Título Customizado",
          "info": "Deixe em branco para usar o nome original da coleção."
        },
        {
          "type": "text",
          "id": "subtext",
          "label": "Subtexto",
          "default": "explore"
        },
        {
          "type": "header",
          "content": "Estilo do Bloco"
        },
        {
          "type": "select",
          "id": "heading_tag",
          "label": "Heading Tag (SEO)",
          "options": [
            { "value": "h2", "label": "H2" },
            { "value": "h3", "label": "H3" },
            { "value": "h4", "label": "H4" },
            { "value": "p", "label": "p" }
          ],
          "default": "h2"
        },
        {
          "type": "font_picker",
          "id": "title_font",
          "label": "Fonte do Título",
          "default": "serif"
        },
        {
          "type": "range",
          "id": "title_size",
          "min": 14,
          "max": 60,
          "step": 1,
          "unit": "px",
          "label": "Tamanho do Título",
          "default": 32
        },
        {
          "type": "color",
          "id": "title_color",
          "label": "Cor do Título e Subtexto",
          "default": "#000000"
        },
        {
          "type": "color",
          "id": "bg_color",
          "label": "Cor de Fundo do Banner",
          "default": "#f4f4f4"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Departamento Noir",
      "blocks": [
        { "type": "collection_row" },
        { "type": "collection_row" }
      ]
    }
  ]
}
{% endschema %}

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const rows = document.querySelectorAll('.collection-row');
    
    rows.forEach(row => {
      const carousel = row.querySelector('.row-carousel');
      const prevBtn = row.querySelector('.collection-row__button.prev');
      const nextBtn = row.querySelector('.collection-row__button.next');
      
      if (!carousel || !prevBtn || !nextBtn) return;
      
      const scrollAmount = 300; // Ajuste conforme necessário
      
      nextBtn.addEventListener('click', () => {
        carousel.scrollBy({ left: scrollAmount, behavior: 'smooth' });
      });
      
      prevBtn.addEventListener('click', () => {
        carousel.scrollBy({ left: -scrollAmount, behavior: 'smooth' });
      });

      // Esconder setas se não houver scroll possível (opcional)
      carousel.addEventListener('scroll', () => {
        prevBtn.style.opacity = carousel.scrollLeft <= 0 ? '0.3' : '1';
        const maxScroll = carousel.scrollWidth - carousel.clientWidth;
        nextBtn.style.opacity = carousel.scrollLeft >= maxScroll - 5 ? '0.3' : '1';
      });
    });
  });
</script>
