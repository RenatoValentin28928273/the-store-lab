{%- style -%}
  {%- if section.settings.title_font != blank -%}
    {{ section.settings.title_font | font_face: font_display: 'swap' }}
  {%- endif -%}

  .list-collections-noir {
    padding: 60px 0;
    background-color: {{ section.settings.section_bg_color | default: '#ffffff' }};
  }
  .list-collections-noir__header {
    max-width: 800px;
    margin-bottom: 60px;
  }
  .list-collections-noir__title {
    font-family: {% if section.settings.title_font != blank %}{{ section.settings.title_font.family }}, {{ section.settings.title_font.fallback_families }}{% else %}serif{% endif %};
    font-size: {{ section.settings.title_size }}px;
    color: {{ section.settings.title_color }};
    line-height: 1.1;
    text-transform: uppercase;
    margin-bottom: 20px;
  }
  .list-collections-noir__description {
    font-size: {{ section.settings.desc_size }}px;
    color: {{ section.settings.desc_color }};
    line-height: 1.6;
  }
  
  /* Filtros Horizontais */
  .list-collections-noir__filters {
    display: flex;
    gap: 10px;
    margin-bottom: 60px;
    overflow-x: auto;
    padding-bottom: 15px;
    border-bottom: 1px solid #eee;
  }
  .list-collections-noir__filter-item {
    flex: 1;
    min-width: 150px;
    padding: 15px;
    border: 1px solid {{ section.settings.filter_text_color | default: '#000' }};
    background-color: {{ section.settings.filter_bg_color | default: 'transparent' }};
    text-align: center;
    text-transform: uppercase;
    font-size: {{ section.settings.filter_font_size | default: 11 }}px;
    letter-spacing: 0.1em;
    text-decoration: none;
    color: {{ section.settings.filter_text_color | default: '#000' }};
    transition: all 0.3s;
  }
  .list-collections-noir__filter-item:hover {
    background: {{ section.settings.filter_text_color | default: '#000' }};
    color: {{ section.settings.filter_bg_color | default: '#fff' }};
  }

  /* Subcategoria Row */
  .collection-row {
    margin-bottom: 80px;
  }
  .collection-row__header {
    padding: 20px;
    text-align: center;
    margin-bottom: 30px;
  }
  .collection-row__title {
    font-family: serif;
    font-size: {{ section.settings.block_title_size }}px;
    color: {{ section.settings.block_title_color }};
    text-transform: uppercase;
    margin: 0;
  }
  .collection-row__subtext {
    font-size: 12px;
    text-transform: lowercase;
    display: block;
    margin-top: 5px;
    opacity: 0.8;
  }

  /* Carousel */
  .row-carousel-container {
    position: relative;
    overflow: hidden;
  }
  .row-carousel {
    display: flex;
    gap: 20px;
    transition: transform 0.5s ease;
    padding: 0 20px;
  }
  .row-carousel__item {
    flex: 0 0 calc(20% - 16px);
    min-width: 200px;
  }

  .collection-row__footer {
    text-align: center;
    margin-top: 30px;
  }
  .collection-row__view-all {
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #000;
    text-decoration: underline;
  }

  @media (max-width: 1024px) {
    .row-carousel__item {
      flex: 0 0 calc(33.33% - 14px);
    }
  }
  @media (max-width: 768px) {
    .row-carousel__item {
      flex: 0 0 70%;
    }
    .row-carousel {
      overflow-x: auto;
      scroll-snap-type: x mandatory;
    }
    .row-carousel__item {
      scroll-snap-align: start;
    }
    .list-collections-noir__title {
      font-size: 2.5rem;
    }
  }
{%- endstyle -%}

<div class="list-collections-noir section-{{ section.id }}">
  <div class="container">
    
    <!-- Cabeçalho do Departamento -->
    <header class="list-collections-noir__header">
      <{{ section.settings.heading_tag | default: 'h1' }} class="list-collections-noir__title">{{ section.settings.title }}</{{ section.settings.heading_tag | default: 'h1' }}>
      {% if section.settings.description != blank %}
        <div class="list-collections-noir__description">
          {{ section.settings.description }}
        </div>
      {% endif %}
    </header>

    <!-- Barra de Filtros (Links Rápidos para as Coleções da Página) -->
    <nav class="list-collections-noir__filters">
      {% for block in section.blocks %}
        {%- if block.settings.collection != blank -%}
          <a href="#collection-{{ block.id }}" class="list-collections-noir__filter-item">
            {{ block.settings.title | default: block.settings.collection.title }}
          </a>
        {%- endif -%}
      {% endfor %}
    </nav>

    <!-- Listagem das Coleções -->
    <div class="list-collections-noir__rows">
      {% for block in section.blocks %}
        {%- assign collection = block.settings.collection -%}
        {%- if collection != blank -%}
          <div class="collection-row" id="collection-{{ block.id }}" {{ block.shopify_attributes }}>
            
            <div class="collection-row__header" style="background-color: {{ block.settings.bg_color | default: '#f4f4f4' }};">
              <h2 class="collection-row__title">{{ block.settings.title | default: collection.title }}</h2>
              <span class="collection-row__subtext">subtext: {{ block.settings.subtext | default: 'explore a categoria' }}</span>
            </div>

            <div class="row-carousel-container">
              <div class="row-carousel">
                {% for product in collection.products limit: 10 %}
                  <div class="row-carousel__item">
                    {% render 'product-card-noir', product: product %}
                  </div>
                {% endfor %}
              </div>
            </div>

            <div class="collection-row__footer">
              <a href="{{ collection.url }}" class="collection-row__view-all">Ver todos</a>
            </div>
          </div>
        {%- endif -%}
      {% endfor %}
    </div>

  </div>
</div>

{% schema %}
{
  "name": "Departamento Noir",
  "settings": [
    {
      "type": "header",
      "content": "Estilo da Seção"
    },
    {
      "type": "color",
      "id": "section_bg_color",
      "label": "Cor de Fundo da Seção",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "SEO e Títulos"
    },
    {
      "type": "select",
      "id": "heading_tag",
      "label": "Tag de Título (SEO)",
      "options": [
        { "value": "h1", "label": "H1" },
        { "value": "h2", "label": "H2" }
      ],
      "default": "h1"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Título do Departamento",
      "default": "Roupas (Departamento)"
    },
    {
      "type": "font_picker",
      "id": "title_font",
      "label": "Fonte do Título",
      "default": "helvetica_n4"
    },
    {
      "type": "range",
      "id": "title_size",
      "min": 20,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Tamanho do Título",
      "default": 56
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Cor do Título",
      "default": "#000000"
    },
    {
      "type": "header",
      "content": "Descrição"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Descrição SEO",
      "default": "<p>Introdução com até 1000 caracteres trabalhando a palavra-chave principal no início e com um CTA.</p>"
    },
    {
      "type": "range",
      "id": "desc_size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Tamanho da Descrição",
      "default": 16
    },
    {
      "type": "color",
      "id": "desc_color",
      "label": "Cor da Descrição",
      "default": "#666666"
    },
    {
      "type": "header",
      "content": "Blocos de Categoria (H2)"
    },
    {
      "type": "range",
      "id": "block_title_size",
      "min": 16,
      "max": 60,
      "step": 1,
      "unit": "px",
      "label": "Tamanho do Título das categorias",
      "default": 28
    },
    {
      "type": "color",
      "id": "block_title_color",
      "label": "Cor do Título das categorias",
      "default": "#000000"
    },
    {
      "type": "header",
      "content": "Barra de Filtros"
    },
    {
      "type": "color",
      "id": "filter_bg_color",
      "label": "Cor de Fundo dos Filtros",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "filter_text_color",
      "label": "Cor do Texto/Borda dos Filtros",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "filter_font_size",
      "min": 10,
      "max": 20,
      "step": 1,
      "unit": "px",
      "label": "Tamanho da Fonte dos Filtros",
      "default": 11
    }
  ],
  "blocks": [
    {
      "type": "collection_row",
      "name": "Sub-coleção",
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "Coleção"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Título Customizado (H2)",
          "info": "Deixe em branco para usar o nome original da coleção."
        },
        {
          "type": "text",
          "id": "subtext",
          "label": "Subtexto",
          "default": "explore"
        },
        {
          "type": "color",
          "id": "bg_color",
          "label": "Cor de Fundo do Título",
          "default": "#f4f4f4"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Departamento Noir",
      "blocks": [
        { "type": "collection_row" },
        { "type": "collection_row" }
      ]
    }
  ]
}
{% endschema %}
