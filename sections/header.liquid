<script>
  document.addEventListener('DOMContentLoaded', function() {
    const navItems = document.querySelectorAll('.main-nav-item');
    const panels = document.querySelectorAll('.submenu-panel');

    navItems.forEach(item => {
      // Usar 'mouseenter' para Desktop e 'click' para uma melhor experiência geral
      const handleActivation = () => {
        const target = item.getAttribute('data-target');
        
        // Atualizar itens da esquerda
        navItems.forEach(i => i.classList.remove('is-active'));
        item.classList.add('is-active');
        
        // Atualizar painéis da direita
        panels.forEach(p => p.classList.remove('is-active'));
        const activePanel = document.getElementById(target);
        if (activePanel) activePanel.classList.add('is-active');
      };

      item.addEventListener('mouseenter', handleActivation);
      item.addEventListener('click', (e) => {
        if (window.innerWidth <= 768) {
           handleActivation();
        }
      });
    });
  });
</script>
