{% schema %}
{
  "name": "Header Noir",
  "settings": [
    {
      "type": "header",
      "content": "Logo"
    },
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo da Loja"
    },
    {
      "type": "range",
      "id": "logo_width",
      "min": 50,
      "max": 300,
      "step": 5,
      "unit": "px",
      "label": "Largura do Logo",
      "default": 100
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Menu Principal"
    },
    {
      "type": "header",
      "content": "Estilo do Header"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Cor de Fundo",
      "default": "#F4F4F4"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Cor do Texto",
      "default": "#000000"
    },
    {
      "type": "font_picker",
      "id": "font_family",
      "label": "Fonte",
      "default": "helvetica_n4"
    },
    {
      "type": "range",
      "id": "font_size",
      "min": 10,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Tamanho da Fonte",
      "default": 13
    },
    {
      "type": "header",
      "content": "Ticker do Header"
    },
    {
      "type": "checkbox",
      "id": "show_ticker",
      "label": "Mostrar Ticker",
      "default": true
    },
    {
      "type": "color",
      "id": "ticker_bg_color",
      "label": "Cor de Fundo do Ticker",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "ticker_text_color",
      "label": "Cor do Texto do Ticker",
      "default": "#FFFFFF"
    },
    {
      "type": "font_picker",
      "id": "ticker_font_family",
      "label": "Fonte do Ticker",
      "default": "helvetica_n4"
    },
    {
      "type": "range",
      "id": "ticker_font_size",
      "min": 10,
      "max": 20,
      "step": 1,
      "unit": "px",
      "label": "Tamanho da Fonte do Ticker",
      "default": 11
    },
    {
      "type": "header",
      "content": "Botões de Ação"
    },
    {
      "type": "range",
      "id": "btn_radius",
      "min": 0,
      "max": 50,
      "step": 1,
      "unit": "px",
      "label": "Arredondamento dos Botões",
      "default": 4
    },
    {
      "type": "color",
      "id": "btn_bg_color",
      "label": "Cor de Fundo (Padrão)",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "btn_border_color",
      "label": "Cor da Borda",
      "default": "#E2E2E2"
    },
    {
      "type": "color",
      "id": "btn_text_color",
      "label": "Cor do Texto",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "bag_btn_bg_color",
      "label": "Cor de Fundo da Bag",
      "default": "#FADC5B"
    },
    {
      "type": "color",
      "id": "bag_btn_text_color",
      "label": "Cor do Texto da Bag",
      "default": "#000000"
    },
    {
      "type": "text",
      "id": "search_label",
      "label": "Texto: Busca",
      "default": "Search"
    },
    {
      "type": "text",
      "id": "account_label",
      "label": "Texto: Conta",
      "default": "Account"
    },
    {
      "type": "text",
      "id": "wishlist_label",
      "label": "Texto: Favoritos",
      "default": "Wishlist"
    },
    {
      "type": "text",
      "id": "bag_label",
      "label": "Texto: Carrinho",
      "default": "Bag"
    },
    {
      "type": "checkbox",
      "id": "show_search",
      "label": "Mostrar Busca",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_account",
      "label": "Mostrar Conta",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_wishlist",
      "label": "Mostrar Favoritos",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_bag",
      "label": "Mostrar Carrinho",
      "default": true
    },
    {
      "type": "header",
      "content": "Barra de Busca (Overlay)"
    },
    {
      "type": "color",
      "id": "search_btn_bg",
      "label": "Cor do Botão de Busca",
      "default": "#2D623B"
    },
    {
      "type": "color",
      "id": "search_btn_text",
      "label": "Cor do Texto do Botão",
      "default": "#FFFFFF"
    }
  ],
  "blocks": [
    {
      "type": "ticker",
      "name": "Item do Ticker",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Texto",
          "default": "✦ Frete grátis para todo o Brasil ✦"
        }
      ]
    }
  ]
}
{% endschema %}

{%- if section.settings.font_family != blank -%}
  <style>
    {{ section.settings.font_family | font_face: font_display: 'swap' }}
  </style>
{%- endif -%}

{%- if section.settings.ticker_font_family != blank -%}
  <style>
    {{ section.settings.ticker_font_family | font_face: font_display: 'swap' }}
  </style>
{%- endif -%}

{% if section.settings.show_ticker and section.blocks.size > 0 %}
  <div id="header-ticker-{{ section.id }}">
    <div class="header-ticker-track">
      {% for block in section.blocks %}
        {% if block.type == 'ticker' %}
          <p class="header-ticker-item" {{ block.shopify_attributes }}>{{ block.settings.text }}</p>
        {% endif %}
      {% endfor %}
    </div>
  </div>
{% endif %}
 
 <header class="header">
  <!-- Lado Esquerdo: Menu Hamburger -->
  <button class="menu-btn" onclick="document.getElementById('menuDrawer').classList.add('active'); document.getElementById('menuDrawerOverlay').classList.add('active');">
    <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path d="M4 6h16M4 12h16M4 18h16"/></svg> 
    Menu
  </button>

  <!-- Menu Drawer Overlay & Content -->
  <div class="menu-drawer-overlay" id="menuDrawerOverlay" onclick="document.getElementById('menuDrawer').classList.remove('active'); this.classList.remove('active');"></div>
  <div class="menu-drawer" id="menuDrawer">
      <div class="menu-drawer-header">
          <div class="menu-close-btn" onclick="document.getElementById('menuDrawer').classList.remove('active'); document.getElementById('menuDrawerOverlay').classList.remove('active');">
              <svg width="18" height="18" fill="none" stroke="#000" stroke-width="2" viewBox="0 0 24 24"><path d="M6 18L18 6M6 6l12 12"/></svg>
              <span>FECHAR</span>
          </div>
      </div>
      
      <div class="menu-columns">
        <!-- Coluna Esquerda: Categorias Principais -->
        <div class="menu-column-left">
          <nav class="main-nav-list">
            {%- assign main_menu = section.settings.menu | default: linklists.main-menu -%}
            {%- if main_menu != blank -%}
              {% for link in main_menu.links %}
                <div class="main-nav-item {% if forloop.first %}is-active{% endif %}" data-target="panel-{{ link.handle }}-{{ forloop.index }}">
                  <a href="{{ link.url }}" class="main-nav-link">
                    {{ link.title | uppercase }}
                    {% if link.links != blank %}
                      <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path d="M9 5l7 7-7 7"/></svg>
                    {% endif %}
                  </a>
                </div>
              {% endfor %}
            {%- endif -%}
          </nav>

          <!-- Utilidades na base da coluna esquerda -->
          <div class="menu-utilities">
            <a href="/pages/contact" class="utility-link">
              <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
              CONTATO
            </a>
            <a href="/pages/stores" class="utility-link">
              <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
              NOSSAS LOJAS
            </a>
            <a href="/account" class="utility-link">
              <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
              ENTRAR / CADASTRAR
            </a>
          </div>
        </div>

        <!-- Coluna Direita: Subcategorias Dinâmicas -->
        <div class="menu-column-right">
          {%- if main_menu != blank -%}
            {% for link in main_menu.links %}
              <div class="submenu-panel {% if forloop.first %}is-active{% endif %}" id="panel-{{ link.handle }}-{{ forloop.index }}">
                
                <!-- Links de Destaque -->
                <div class="featured-sublinks">
                  <a href="{{ link.url }}" class="featured-link">VER TUDO EM {{ link.title | uppercase }}</a>
                </div>

                <div class="submenu-grid">
                  {%- if link.links != blank -%}
                    {%- for childlink in link.links -%}
                      <div class="submenu-group">
                        <h3 class="submenu-group-title">{{ childlink.title | uppercase }}</h3>
                        <ul class="submenu-list">
                          {%- if childlink.links != blank -%}
                            {%- for grandchildlink in childlink.links -%}
                              <li><a href="{{ grandchildlink.url }}">{{ grandchildlink.title }}</a></li>
                            {%- endfor -%}
                          {%- else -%}
                            <li><a href="{{ childlink.url }}">Ver tudo</a></li>
                          {%- endif -%}
                        </ul>
                      </div>
                    {%- endfor -%}
                  {%- else -%}
                    {% comment %} Fallback: Se não houver submenus aninhados, tentamos buscar um menu com o mesmo nome ou apenas listamos o link principal {% endcomment %}
                    <div class="submenu-group">
                      <h3 class="submenu-group-title">{{ link.title | uppercase }}</h3>
                      <ul class="submenu-list">
                        <li><a href="{{ link.url }}">Ver Coleção Completa</a></li>
                        {%- if collections[link.handle].all_types.size > 0 -%}
                          {%- for type in collections[link.handle].all_types -%}
                            <li><a href="{{ collections[link.handle].url }}/{{ type | handleize }}">{{ type }}</a></li>
                          {%- endfor -%}
                        {%- endif -%}
                      </ul>
                    </div>
                  {%- endif -%}
                </div>
              </div>
            {% endfor %}
          {%- endif -%}
        </div>
      </div>
  </div>

  <script>
    document.addEventListener("DOMContentLoaded", function() {
        const overlay = document.getElementById('menuDrawerOverlay');
        const drawer = document.getElementById('menuDrawer');
        if (overlay && drawer) {
            document.body.appendChild(overlay);
            document.body.appendChild(drawer);
        }
    });
  </script>

  <!-- Centro: Logo -->
  <div class="header-logo">
    <a href="/">
      {% if section.settings.logo != blank %}
        <img src="{{ section.settings.logo | image_url: width: section.settings.logo_width }}" 
             alt="{{ shop.name }}"
             width="{{ section.settings.logo_width }}"
             height="{{ section.settings.logo_width | divided_by: section.settings.logo.aspect_ratio | round }}"
             loading="eager"
             class="header-logo-img">
      {% else %}
        <span class="header-logo-text">{{ shop.name | upcase }}</span>
      {% endif %}
    </a>
  </div>

  <!-- Lado Direito: Ações em Bloco -->
  <div class="header-actions">
    {% if section.settings.show_search %}
      <a href="/search" class="header-btn js-open-search">
        <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg> 
        {{ section.settings.search_label }}
      </a>
    {% endif %}

    {% if section.settings.show_account %}
      <a href="/account" class="header-btn">
        <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2M12 11a4 4 0 100-8 4 4 0 000 8z"/></svg> 
        {{ section.settings.account_label }}
      </a>
    {% endif %}

    {% if section.settings.show_wishlist %}
      <a href="#wishlist" class="header-btn">
        <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/></svg> 
        {{ section.settings.wishlist_label }}
      </a>
    {% endif %}

    {% if section.settings.show_bag %}
      <a href="/cart" class="header-btn bag-btn">
        <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"/></svg> 
        {{ section.settings.bag_label }} ({{ cart.item_count }})
      </a>
    {% endif %}
  </div>

  <!-- Barra de Busca Overlay (Dentro do Header para herdar contexto) -->
  <div class="search-overlay" id="searchOverlay">
    <div class="search-overlay-container">
      <form action="/search" method="get" class="search-overlay-form">
        <input type="text" name="q" placeholder="Search {{ shop.name }}.com" class="search-overlay-input" autocomplete="off">
        <button type="submit" class="search-overlay-submit">Search</button>
        <button type="button" class="search-overlay-cancel" id="closeSearch">CANCELAR</button>
      </form>
      <div class="search-overlay-results" id="searchResults"></div>
    </div>
  </div>
</header>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const searchBtn = document.querySelector('.js-open-search');
    const searchOverlay = document.getElementById('searchOverlay');
    const searchCancel = document.getElementById('closeSearch');
    const searchInput = document.querySelector('.search-overlay-input');

    if (searchBtn && searchOverlay) {
      searchBtn.addEventListener('click', function(e) {
        e.preventDefault();
        searchOverlay.classList.add('active');
        setTimeout(() => searchInput.focus(), 100);
      });
    }

    if (searchCancel && searchOverlay) {
      searchCancel.addEventListener('click', function() {
        searchOverlay.classList.remove('active');
        document.getElementById('searchResults').innerHTML = '';
        searchInput.value = '';
      });
    }

    // Predictive Search Logic
    const searchResults = document.getElementById('searchResults');
    let debounceTimer;

    searchInput.addEventListener('input', function() {
      clearTimeout(debounceTimer);
      const query = this.value.trim();

      if (query.length < 3) {
        searchResults.innerHTML = '';
        searchResults.classList.remove('has-results');
        return;
      }

      debounceTimer = setTimeout(() => {
        fetch(`/search/suggest.json?q=${encodeURIComponent(query)}&resources[type]=product&resources[limit]=4`)
          .then(response => response.json())
          .then(suggestions => {
            const products = suggestions.resources.results.products;
            if (products.length > 0) {
              renderSearchProducts(products);
            } else {
              searchResults.innerHTML = '<div class="no-results">Nenhum produto encontrado.</div>';
              searchResults.classList.add('has-results');
            }
          });
      }, 300);
    });

    function renderSearchProducts(products) {
      let html = '<div class="search-results-grid">';
      products.forEach(product => {
        html += `
          <a href="${product.url}" class="search-product-card">
            <div class="search-product-image">
              <img src="${product.image}" alt="${product.title}" loading="lazy">
            </div>
            <div class="search-product-info">
              <h4 class="search-product-title">${product.title}</h4>
              <p class="search-product-price">${product.price}</p>
            </div>
          </a>
        `;
      });
      html += '</div>';
      searchResults.innerHTML = html;
      searchResults.classList.add('has-results');
    }
  });
</script>

<style>
.header {
    position: relative;
}
.search-overlay {
    position: absolute;
    top: 0; left: 0; width: 100%; height: auto;
    min-height: 80px;
    background: #fff;
    z-index: 1000;
    display: flex;
    flex-direction: column;
    justify-content: center;
    visibility: hidden;
    opacity: 0;
    transition: all 0.2s ease;
    padding: 20px 0;
}
.search-overlay.active {
    visibility: visible;
    opacity: 1;
}
.search-overlay-container {
    width: 100%;
    max-width: 1440px;
    margin: 0 auto;
    padding: 0 40px;
}
.search-overlay-results {
    margin-top: 30px;
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.3s ease;
}
.search-overlay-results.has-results {
    max-height: 600px;
    padding-bottom: 20px;
}

.search-results-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
}

.search-product-card {
    text-decoration: none;
    color: inherit;
    display: block;
    animation: fadeIn 0.3s ease forwards;
}

.search-product-image {
    aspect-ratio: 4/5;
    background: #f5f5f5;
    margin-bottom: 10px;
    overflow: hidden;
}

.search-product-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
}

.search-product-title {
    font-size: 13px;
    font-weight: 500;
    margin: 0 0 5px 0;
    text-transform: uppercase;
    letter-spacing: 0.05em;
}

.search-product-price {
    font-size: 13px;
    color: #666;
    margin: 0;
}

.no-results {
    text-align: center;
    font-size: 14px;
    color: #999;
    padding: 20px 0;
}

@keyframes fadeIn {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
}
.search-overlay-form {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 15px;
}
.search-overlay-input {
    width: 450px;
    border: 1px solid #000;
    padding: 10px 15px;
    font-size: 15px;
    outline: none;
    color: #333;
    font-family: inherit;
}
.search-overlay-input::placeholder {
    color: #999;
}
.search-overlay-submit {
    background-color: {{ section.settings.search_btn_bg }};
    color: {{ section.settings.search_btn_text }};
    border: none;
    padding: 10px 25px;
    font-size: 14px;
    font-weight: 700;
    cursor: pointer;
    border-radius: 8px;
    text-transform: none;
    line-height: normal;
}
.search-overlay-cancel {
    background: none;
    border: none;
    font-size: 12px;
    font-weight: 700;
    cursor: pointer;
    text-decoration: underline;
    text-transform: uppercase;
    color: #000;
    letter-spacing: 0.05em;
    padding: 0;
    margin-left: 10px;
}

#shopify-section-{{ section.id }} .header {
    background-color: {{ section.settings.bg_color }};
    color: {{ section.settings.text_color }};
    font-size: {{ section.settings.font_size }}px;
    {%- if section.settings.font_family != blank -%}
    font-family: {{ section.settings.font_family.family }}, {{ section.settings.font_family.fallback_families }};
    font-weight: {{ section.settings.font_family.weight }};
    font-style: {{ section.settings.font_family.style }};
    {%- endif -%}
}

#shopify-section-{{ section.id }} .header-logo-text,
#shopify-section-{{ section.id }} .menu-btn {
    color: {{ section.settings.text_color }};
}

.header-logo {
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    align-items: center;
    justify-content: center;
}

.header-logo a {
    text-decoration: none;
    color: inherit;
    display: flex;
}

.header-logo-img {
    display: block;
    height: auto;
}

.header-logo-text {
    font-size: 24px;
    font-weight: 800;
    letter-spacing: 0.1em;
}

#shopify-section-{{ section.id }} .header-btn {
    background-color: {{ section.settings.btn_bg_color }};
    color: {{ section.settings.btn_text_color }};
    border-color: {{ section.settings.btn_border_color }};
    border-radius: {{ section.settings.btn_radius }}px;
}

#shopify-section-{{ section.id }} .header-btn svg {
    color: {{ section.settings.btn_text_color }};
}

#shopify-section-{{ section.id }} .bag-btn {
    background-color: {{ section.settings.bag_btn_bg_color }};
    color: {{ section.settings.bag_btn_text_color }};
    border-color: {{ section.settings.bag_btn_bg_color }};
}

#shopify-section-{{ section.id }} .bag-btn svg {
    color: {{ section.settings.bag_btn_text_color }};
}

{% if section.settings.show_ticker %}
#header-ticker-{{ section.id }} {
    background-color: {{ section.settings.ticker_bg_color }};
    color: {{ section.settings.ticker_text_color }};
    font-size: {{ section.settings.ticker_font_size }}px;
    {%- if section.settings.ticker_font_family != blank -%}
    font-family: {{ section.settings.ticker_font_family.family }}, {{ section.settings.ticker_font_family.fallback_families }};
    font-weight: {{ section.settings.ticker_font_family.weight }};
    font-style: {{ section.settings.ticker_font_family.style }};
    {%- endif -%}
    padding: 8px 20px;
    text-align: center;
}
.header-ticker-track {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 32px;
    flex-wrap: wrap;
}
.header-ticker-item {
    margin: 0;
    text-transform: uppercase;
    letter-spacing: 0.1em;
}
{% endif %}

#shopify-section-{{ section.id }} {
    position: sticky;
    top: 33px; /* Valor aproximado para a barra de anúncio */
    z-index: 1000;
}
.header {
    height: 64px;
    background-color: var(--color-off-white);
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 40px;
    border-bottom: 1px solid var(--border-color);
}

.header-logo {
    font-size: 20px;
    font-weight: 700;
    letter-spacing: 0.2em;
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
}

/* --- Megamenu & Desktop Nav --- */
@media (max-width: 989px) {
    .hide-mobile { display: none !important; }
}
@media (min-width: 990px) {
    .hide-desktop { display: none !important; }
}

.header-menu {
    display: flex;
    gap: 32px;
    list-style: none;
    margin: 0;
    padding: 0;
    height: 100%;
