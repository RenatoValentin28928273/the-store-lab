{% comment %}
  Snippet para o Card de Produto Noir - Estilo Editorial
  Uso: {% render 'product-card-noir', product: product %}
{% endcomment %}

<div class="product-card-noir">
  {%- comment -%} O Link agora envolve o conteúdo mas também tem uma camada invisível que cobre tudo abaixo {%- endcomment -%}
  <a href="{{ product.url }}" class="product-card-noir__full-link" aria-label="{{ product.title }}">
    <div class="product-card-noir__image-wrapper">
      {%- if product.featured_media -%}
        {{ product.featured_media | image_url: width: 800 | image_tag: 
          loading: 'lazy', 
          class: 'product-card-noir__image',
          widths: '400, 600, 800'
        }}
      {%- else -%}
        {{ 'product-1' | placeholder_svg_tag: 'product-card-noir__image' }}
      {%- endif -%}

      {%- if product.compare_at_price > product.price -%}
        <span class="product-card-noir__badge">SALE</span>
      {%- endif -%}
    </div>

    <div class="product-card-noir__info">
      <h3 class="product-card-noir__title">{{ product.title | uppercase }}</h3>
      
      <p class="product-card-noir__subtitle">
        {%- if product.metafields.descriptors.subtitle != blank -%}
          {{ product.metafields.descriptors.subtitle }}
        {%- else -%}
          {{ product.type }}
        {%- endif -%}
      </p>

      {%- if product.options_by_name['Color'] or product.options_by_name['Cor'] -%}
        <div class="product-card-noir__swatches">
          {%- assign color_option = product.options_by_name['Color'] | default: product.options_by_name['Cor'] -%}
          {%- for value in color_option.values limit: 5 -%}
            <span class="product-card-noir__swatch" style="background-color: {{ value | split: ' ' | last | handle }};"></span>
          {%- endfor -%}
        </div>
      {%- endif -%}

      <div class="product-card-noir__price">
        <span class="product-card-noir__price--current">{{ product.price | money }}</span>
      </div>
    </div>
  </a>
</div>

<style>
  .product-card-noir {
    position: relative;
    display: block;
    width: 100%;
    cursor: pointer;
  }

  .product-card-noir__full-link {
    display: block;
    text-decoration: none;
    color: inherit;
    position: relative;
    z-index: 5;
  }

  /* Camada invisível que garante que qualquer clique no card funcione como link */
  .product-card-noir__full-link::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 10;
  }

  .product-card-noir__image-wrapper {
    position: relative;
    aspect-ratio: 3/4;
    overflow: hidden;
    background-color: #f9f9f9;
    margin-bottom: 15px;
  }

  .product-card-noir__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s cubic-bezier(0.165, 0.84, 0.44, 1);
  }

  .product-card-noir:hover .product-card-noir__image {
    transform: scale(1.05);
  }

  .product-card-noir__info {
    display: flex;
    flex-direction: column;
    gap: 4px;
    padding: 0 4px;
  }

  .product-card-noir__title {
    margin: 0;
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.05em;
    color: #000;
  }

  .product-card-noir__subtitle {
    margin: 0;
    font-size: 11px;
    color: #888;
    text-transform: uppercase;
  }

  .product-card-noir__swatches {
    display: flex;
    gap: 6px;
    margin: 8px 0;
  }

  .product-card-noir__swatch {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    border: 1px solid #eee;
  }

  .product-card-noir__price {
    font-size: 14px;
    font-weight: 700;
    color: #000;
    margin-top: 4px;
  }
</style>
